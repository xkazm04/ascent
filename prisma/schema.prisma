// Ascent — Phase 2 persistence schema.
//
// DSQL-safe by design (works identically on local Postgres and Amazon Aurora DSQL):
//   - relationMode = "prisma"  -> NO foreign-key constraints emitted (DSQL doesn't
//     support FKs); relations are enforced at the Prisma layer. Requires manual
//     @@index on relation scalar fields (added below).
//   - UUID primary keys via @default(uuid())  -> no SERIAL / sequences (DSQL has none).
//   - Bulky string arrays are stored as serialized JSON in text columns (no jsonb
//     dependency); queryable fields (scores, level, timestamps) are real columns so
//     trend/history queries stay relational.
//
// On DSQL, create indexes asynchronously (CREATE INDEX ASYNC ...) — see
// docs/ARCHITECTURE.md. Migrations: Prisma is supported by DSQL (since 2026-02).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Organization {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  plan            String   @default("free") // free | pro | team | enterprise
  // Prepaid private-scan credit balance. Public scans are free + unmetered; each private (installation)
  // scan that runs real LLM inference debits one credit (see src/lib/db/credits.ts + src/lib/entitlement.ts).
  // `enterprise` plan is treated as unlimited (no debit). Credits are granted out-of-band (a Polar
  // top-up, or an owner/admin grant) — see docs/BILLING.md. The CreditLedger is the audit trail.
  scanCredits     Int      @default(0)
  // Per-org data-retention overrides (enterprise). null = inherit the global env default
  // (RETENTION_MAX_SCANS_PER_REPO / RETENTION_AUDIT_DAYS); 0 = keep everything (unlimited).
  // Enforced by the /api/cron/purge job — see src/lib/db/retention.ts.
  retentionMaxScans  Int?
  retentionAuditDays Int?
  // Per-org alert sink (Slack-compatible incoming webhook). Regression alerts, low-credit pushes and
  // the weekly digest route HERE when set, falling back to the global ALERT_WEBHOOK_URL env — so each
  // tenant receives its own fleet intelligence instead of everything landing in the operator's channel.
  // null = inherit the global sink (or a clean no-op when that's unset too). See src/lib/db/org-alerts.ts.
  alertWebhookUrl String?
  // Per-org regression sensitivity (points). null = inherit DEFAULT_THRESHOLDS (overall 5 / dim 15).
  // Threaded into detectRegression by checkAndAlertRegression — see src/lib/scan-alerts.ts.
  alertOverallDrop   Int?
  alertDimensionDrop Int?
  // Per-org CI maturity-gate policy (GatePolicy JSON). null = archetype default. Honored by the
  // App-mode PR Check Run + the governance fleet view — see src/lib/db/org-gate.ts.
  gatePolicy      Json?
  // White-label branding for the executive briefing (EXEC-5, enterprise) — null = the Ascent default.
  // brandColor is a #rrggbb accent; logoUrl an https image rendered in the PDF header. See briefing.
  brandName       String?
  brandColor      String?
  logoUrl         String?
  githubInstallId String?
  createdAt       DateTime @default(now())

  memberships   Membership[]
  repositories  Repository[]
  auditLogs     AuditLog[]
  subscription  Subscription?
  creditLedger  CreditLedger[]
  goals         Goal[]
  initiatives   Initiative[]
  segments      Segment[]
  playbooks     Playbook[]
  invites       Invite[]
  orgSkills     OrgSkill[]
  techGroups    TechStackGroup[]
  llmConfig     OrgLlmConfig?
}

// Append-only ledger of scan-credit movements — the trustworthy record behind Organization.scanCredits.
// One row per grant (+) or per-scan debit (-), each stamping the resulting balance so the running total
// can be audited and reconciled against billing top-ups (Polar). Standalone under relationMode="prisma"
// (no DB FKs); always queried by orgId. See src/lib/db/credits.ts.
model CreditLedger {
  id           String   @id @default(uuid())
  orgId        String
  delta        Int // +N granted, -N debited
  balanceAfter Int // org.scanCredits immediately after applying this row (within the same txn)
  reason       String   @default("scan") // scan | grant | polar | adjustment | refund
  repoFullName String? // the repo a scan debit paid for (null for grants/adjustments)
  scanId       String? // the Scan row a debit paid for, when known
  actor        String? // GitHub login (grant/adjustment) or the billing provider ("polar"/"system")
  // Idempotency key for externally-fulfilled grants — the Polar order id, prefixed "polar:". UNIQUE so a
  // webhook redelivery can't double-grant: grantCredits short-circuits when a row with this id exists,
  // and a racing duplicate insert hits this constraint and rolls back. Null for scans/manual grants.
  // See src/app/api/billing/webhook/route.ts.
  externalId   String?  @unique
  createdAt    DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([orgId, createdAt])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  // GitHub login — the identity the session actually carries (auth is GitHub-OAuth/App based, not
  // email/password). Bridges a session to a Membership row so RBAC (Membership.role) can be resolved
  // and persisted for the logins we know. Email is kept (unique, required) and set to the GitHub
  // noreply form for App/OAuth users. See src/lib/db/members.ts.
  githubLogin String? @unique
  name        String?
  createdAt   DateTime @default(now())

  memberships Membership[]
}

model Membership {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  role      String   @default("member") // owner | admin | member | viewer
  createdAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id])
  user User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

// A pending invitation to join an org at a given role. Bridges the gap before MEM-2: the only
// "add member" path was an owner typing an exact GitHub login into setMembershipRole (a typo
// silently created a ghost membership). An invite carries a single-use `token` (the capability in
// the /invite/[token] link), optionally pins a githubLogin/email, expires, and is consumed by
// acceptInvite → setMembershipRole. See src/lib/db/invites.ts.
model Invite {
  id          String   @id @default(uuid())
  orgId       String
  email       String?
  githubLogin String? // when set, only this login may accept (case-insensitive)
  role        String   @default("member") // owner | admin | member | viewer
  token       String   @unique
  status      String   @default("pending") // pending | accepted | revoked
  invitedBy   String? // GitHub login of the owner who created it
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([status])
}

model Repository {
  id              String    @id @default(uuid())
  orgId           String
  owner           String
  name            String
  fullName        String // "owner/name"
  url             String
  isPrivate       Boolean   @default(false)
  primaryLanguage String?
  // Latest detected tech stack (Feature 3a), cached from the most recent scan for fleet-wide grouping
  // without re-deriving. JSON TechStack (see src/lib/analyze/tech-extract.ts). Null until first scan.
  techStackJson   String?
  // Latest App Readiness Passport (JSON AppPassport) cached from the most recent scan — the portfolio
  // scorecard surfaced/compared without re-deriving. Display-only. Null until first scan.
  passportJson    String?
  // Owner-set passport overrides (P4) for the fields a scan can't observe — JSON
  // { criticality?, lifecycle?, rollback? }. Applied as a read-time overlay over the scan-derived
  // passport (never mutates the stored scan). Null = none set. See src/lib/db/passport-overrides.ts.
  passportOverridesJson String?
  stars           Int       @default(0)
  // Current default-branch head + the GitHub ETag from the last conditional HEAD lookup.
  // Together these back the cross-instance scan cache: a re-scan sends `If-None-Match: headEtag`
  // (a free 304 when unchanged) and serves the persisted scan pinned to headSha — see
  // src/lib/scan-cache.ts. Null until the repo's first anonymous scan records them.
  headSha         String?
  headEtag        String?
  watched         Boolean   @default(false)
  scanSchedule    String    @default("off") // off | daily | weekly | monthly
  lastScanAt      DateTime?
  nextScanAt      DateTime?
  // Outcome of the most recent scan ATTEMPT (bulk/cron), so the dashboard can tell "never scanned"
  // apart from "scanning is broken" (revoked token, deleted repo, rate-limited). Null until first try.
  lastScanStatus    String? // "ok" | "error"
  lastScanError     String?
  lastScanAttemptAt DateTime?
  // `.ai/` standard conformance reported back by the repo's doctor (`node .ai/doctor.mjs --json`),
  // closing the adopt→verify→re-score loop. Null until a conformance report lands. See
  // src/app/api/report/conformance + src/lib/standard/doctor.ts.
  aiConformance     Int? // 0..100 conformance %
  aiConformanceFails Int?
  aiConformanceWarns Int?
  aiConformanceAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org          Organization      @relation(fields: [orgId], references: [id])
  scans        Scan[]
  contributors RepoContributor[]
  teams        RepoTeam[]
  segments     RepoSegment[]
  techGroups   TechStackGroupMember[]

  @@unique([orgId, fullName])
  @@index([orgId])
  @@index([fullName])
  @@index([watched])
}

// A user-defined slice of the fleet — a named tag grouping repos (e.g. "platform", "mobile",
// "legacy", "acquisitions"). Repos are tagged via RepoSegment (many-to-many), so a repo can belong
// to several segments. Every org aggregate (getOrgRollup/Movers/GapAnalysis/Recommendations/
// Contributors) accepts an optional segment filter that scopes it to the tagged repos, and two
// segments can be compared side by side. Org-scoped and uniquely named within an org.
// See src/lib/db/segments.ts.
model Segment {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  color     String   @default("#3b9eff") // accent hex for the chip
  createdAt DateTime @default(now())

  org   Organization  @relation(fields: [orgId], references: [id])
  repos RepoSegment[]

  @@unique([orgId, name])
  @@index([orgId])
}

// Membership of a repo in a segment — the tag join. Toggled per (segment, repo). Standalone under
// relationMode="prisma" (no DB FKs); deleting a segment cascades its rows at the Prisma layer.
model RepoSegment {
  id        String   @id @default(uuid())
  segmentId String
  repoId    String
  createdAt DateTime @default(now())

  segment Segment    @relation(fields: [segmentId], references: [id])
  repo    Repository @relation(fields: [repoId], references: [id])

  @@unique([segmentId, repoId])
  @@index([segmentId])
  @@index([repoId])
}

model RepoContributor {
  id           String    @id @default(uuid())
  repoId       String
  login        String
  name         String?
  commits      Int       @default(0)
  aiCommits    Int       @default(0)
  lastActiveAt DateTime?
  updatedAt    DateTime  @updatedAt

  repo Repository @relation(fields: [repoId], references: [id])

  @@unique([repoId, login])
  @@index([repoId])
}

// A team that owns part of a repo, parsed from its CODEOWNERS file at scan time. The unit behind
// the org's team-level rollups (getOrgTeamRollup): a repo is attributed to every team in its
// CODEOWNERS, so Adoption×Rigor, gaps, movers, and AI-knowledge can aggregate per team. The latest
// scan is authoritative — persistScanReport replaces a repo's full RepoTeam set each scan, so a
// removed/renamed team can't linger. `slug` is the normalized "@org/team" mention (lowercased).
model RepoTeam {
  id             String   @id @default(uuid())
  repoId         String
  slug           String // normalized "@org/team" code-owner mention (lowercased)
  ownedPaths     Int      @default(0) // # of CODEOWNERS rules that name this team
  isDefaultOwner Boolean  @default(false) // owns the "*" catch-all rule (the repo's primary owner)
  source         String   @default("codeowners") // codeowners | github_teams
  updatedAt      DateTime @updatedAt

  repo Repository @relation(fields: [repoId], references: [id])

  @@unique([repoId, slug])
  @@index([repoId])
}

model Scan {
  id             String   @id @default(uuid())
  repoId         String
  headSha        String? // the commit the scan pinned to — powers /report/{owner}/{repo}@{sha} permalinks
  overallScore   Int
  level          String // "L1".."L5"
  levelName      String
  archetype      String   @default("org")
  adoptionScore  Int      @default(0)
  rigorScore     Int      @default(0)
  posture        String   @default("")
  confidence     Float    @default(0)
  engineProvider String
  engineModel    String
  headline       String
  strengths      String   @default("[]") // JSON string[]
  risks          String   @default("[]") // JSON string[]
  // LLM-as-auditor output: suspected deterministic-detector misses, persisted so the
  // detector backlog (getOrgDiscrepancies) can aggregate them across the fleet. JSON Discrepancy[].
  discrepancies  String   @default("[]")
  prStats        String? // JSON PrStats (pull-request process signals); null if no token
  governance     String? // JSON Governance (branch protection / rulesets); null if no token
  commitActivity String? // JSON number[] — last ~12 weekly commit totals; null if no token
  // Per-scan detected tech stack (Feature 3a) — JSON TechStack. Keeps history honest when a repo
  // re-stacks; the latest is also cached on Repository.techStackJson. Display-only (never scored).
  techStackJson  String?
  // Per-scan App Readiness Passport — JSON AppPassport. Per-scan history; latest cached on
  // Repository.passportJson. Display-only (never scored). See src/lib/analyze/passport.ts.
  passportJson   String?
  // LLM cost/usage metering: tokens consumed + the LLM-stage latency for this scan's model call.
  // Null on a mock/keyless scan (no model cost) or a provider that didn't report usage.
  inputTokens    Int?
  outputTokens   Int?
  llmLatencyMs   Int?
  scannedAt      DateTime
  createdAt      DateTime @default(now())

  repo            Repository      @relation(fields: [repoId], references: [id])
  dimensions      ScanDimension[]
  recommendations Recommendation[]

  @@index([repoId])
  @@index([repoId, scannedAt])
  // Cross-instance dedup backstop: two serverless instances persisting the SAME commit concurrently
  // both miss the read-then-insert dedup (the row isn't committed yet) and both insert. A unique
  // constraint makes the loser fail with P2002 (handled in persistScanReport → deduped). headSha is
  // nullable, so sha-less scans (NULLs are distinct in Postgres) are unconstrained and fall back to
  // the scannedAt dedup. Replaces the plain @@index (a unique index also serves the lookup).
  @@unique([repoId, headSha])
}

model ScanDimension {
  id          String @id @default(uuid())
  scanId      String
  dimId       String // "D1".."D9"
  name        String
  weight      Float
  score       Int
  signalScore Int
  llmScore    Int
  summary     String @default("")
  evidence    String @default("[]") // JSON string[]
  strengths   String @default("[]") // JSON string[]
  gaps        String @default("[]") // JSON string[]

  scan Scan @relation(fields: [scanId], references: [id])

  @@index([scanId])
}

model Recommendation {
  id          String   @id @default(uuid())
  scanId      String
  title       String
  dimId       String
  impact      String // high | medium | low
  effort      String // high | medium | low
  rationale   String   @default("")
  explore     String   @default("[]") // JSON string[] — invitational questions to explore the gap
  levelUnlock String?
  status      String   @default("open") // open | in_progress | done | dismissed
  // Ownership + planning layer that turns a scattered list of gaps into a trackable backlog
  // (the assignee/due-date mechanics behind the org-wide backlog view — see getOrgBacklog).
  // Both carry forward across re-scans (matched by dimId+title) so a re-scan doesn't drop who
  // owns a gap or when it's due. null = unassigned / no deadline.
  assigneeLogin String? // GitHub login accountable for closing this gap
  targetDate    DateTime? // optional due date the backlog is paced against
  createdAt   DateTime @default(now())

  scan   Scan                  @relation(fields: [scanId], references: [id])
  events RecommendationEvent[]

  @@index([scanId])
  @@index([status])
  @@index([assigneeLogin])
}

// Append-only activity timeline for a recommendation — one row per status change, (re)assignment,
// or due-date change, capturing who did it (actor), what changed (kind, from → to), and an optional
// note. This is what makes the backlog trustworthy for planning the way Linear/Jira are: a complete,
// ordered audit of how a gap moved from open to done and who owned it along the way. Written in the
// same transaction as the mutation that caused it (see updateRecommendation). Standalone under
// relationMode = "prisma" (no DB FKs); always queried by recommendationId.
model RecommendationEvent {
  id               String   @id @default(uuid())
  recommendationId String
  actor            String? // GitHub login who made the change (null = system / anonymous)
  kind             String   @default("status") // status | assignee | target_date
  fromValue        String? // prior value (status id, login, or ISO date) — null when first set
  toValue          String? // new value — null when cleared
  note             String? // optional free-text note attached to the change
  createdAt        DateTime @default(now())

  recommendation Recommendation @relation(fields: [recommendationId], references: [id])

  @@index([recommendationId])
  @@index([createdAt])
}

model AuditLog {
  id      String   @id @default(uuid())
  orgId   String?
  actorId String?
  action  String
  meta    String   @default("{}") // JSON object
  at      DateTime @default(now())

  org Organization? @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([at])
  // Serves the org-scoped audit viewer's keyset query (where orgId, order by at desc, id desc).
  @@index([orgId, at])
}

model Subscription {
  id        String   @id @default(uuid())
  orgId     String   @unique
  stripeId  String?
  status    String   @default("inactive")
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id])
}

// A maturity target an org is steering toward — the management layer over the trend/forecast.
// `metric` is "overall" | "adoption" | "rigor" | a dimension id ("D1".."D9"); progress is derived
// from the fleet's latest scans at read time (no stored snapshot to drift). `targetDate` is the
// optional deadline the goal is paced against — the trend slope projects an ETA that's compared to
// it to read "on pace / behind / reached". See src/lib/db/plan.ts.
model Goal {
  id         String    @id @default(uuid())
  orgId      String
  label      String
  metric     String    @default("overall")
  target     Int       @default(50)
  targetDate DateTime? // optional deadline the goal is paced against (null = open-ended)
  status     String    @default("active") // active | achieved | archived
  achievedAt DateTime? // when the goal first reached its target (set once by listGoals); null = not met
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

// A tracked, scoped program of work — typically created from a fleet recommendation: "bring
// these N repos up to <target> on <dimension>". Bundles the highest-leverage org move into an
// assignable, status-tracked initiative. `repos` is a JSON string[] of repo fullNames.
model Initiative {
  id            String    @id @default(uuid())
  orgId         String
  title         String
  dimId         String // "D1".."D9"
  practiceId    String? // optional link into the Practice Library
  targetScore   Int       @default(70)
  repos         String    @default("[]") // JSON string[] — repo fullNames in scope
  status        String    @default("open") // open | in_progress | done | dismissed
  assigneeLogin String? // GitHub login of the owner driving the work (null = unassigned)
  targetDate    DateTime? // optional due date the initiative is steered toward (null = open-ended)
  goalId        String? // optional link to the steering Goal this initiative serves (null = standalone)
  playbookId    String? // optional link to the Playbook whose rollout this initiative tracks (null = none)
  createdAt     DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([status])
}

// A company best-practice "playbook" authored by an org owner/admin — the org's own reusable
// standard for a maturity dimension (e.g. "Our CI standard", "Our AGENTS.md template"). Devs browse
// and apply them; later phases tie adoption to dimension lift. `steps` is a JSON string[] of the
// concrete actions. Org-scoped; see src/lib/db/playbooks.ts. Distinct from the DERIVED practice
// library (getOrgPractices), which is inferred from scans rather than authored.
model Playbook {
  id        String   @id @default(uuid())
  orgId     String
  title     String
  dimId     String // "D1".."D9" — the dimension this playbook strengthens
  summary   String   @default("") // what it is / why it matters
  steps     String   @default("[]") // JSON string[] — the concrete starter steps
  createdBy String? // GitHub login of the author
  archived  Boolean  @default(false)
  version   Int      @default(1) // bumped each time the content (title/dim/summary/steps) is edited
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // last content edit (change history anchor)

  org          Organization          @relation(fields: [orgId], references: [id])
  applications PlaybookApplication[]

  @@index([orgId])
}

// Records that a playbook was applied to a repo — the explicit adoption signal (there's no scan
// signal for "this repo adopted playbook X"). Adoption analytics count distinct applied repos and
// measure the dimension-score lift in those repos since `appliedAt`. One row per (playbook, repo).
model PlaybookApplication {
  id             String   @id @default(uuid())
  playbookId     String
  orgId          String // denormalized for org-scoped aggregation
  repoFullName   String
  appliedBy      String? // GitHub login who marked it applied
  appliedVersion Int? // the playbook version this repo adopted (null for pre-versioning marks)
  appliedAt      DateTime @default(now())

  playbook Playbook @relation(fields: [playbookId], references: [id])

  @@unique([playbookId, repoFullName])
  @@index([playbookId])
  @@index([orgId])
}

// Org Skills Library (Feature 2) — a scalable, categorized catalog of reusable Claude/LLM "skills"
// (SKILL.md-like prompt/workflow assets) authored in-app, so members discover and reuse the org's own
// best assets. Mirrors the Playbook stack (org-authored library item + adoption tracking) but adds a
// `category` (indexed) for filtering at scale and a denormalized `downloadCount` for DB-side
// sort-by-most-used. DISTINCT from SkillGeneration (the per-repo onboarding SKILL.md generator) — no
// coupling. `tags` and the body are JSON/TEXT (no jsonb). See src/lib/db/org-skills.ts.
model OrgSkill {
  id            String   @id @default(uuid())
  orgId         String
  name          String // <= 200 chars; unique within the org
  description   String   @default("") // <= 1000
  content       String // the skill body (SKILL.md-like markdown); <= 50KB
  category      String // one of src/lib/org/skill-categories.ts (validated on write)
  tags          String   @default("[]") // JSON string[] — secondary, optional refinement
  version       Int      @default(1) // bumped on a content edit (mirror Playbook), the change-history anchor
  archived      Boolean  @default(false) // soft archive, not hard delete
  downloadCount Int      @default(0) // denormalized rolling tally for DB-side sort-by-downloads (§8.8)
  createdBy     String? // GitHub login of the author
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org       Organization       @relation(fields: [orgId], references: [id])
  adoptions OrgSkillAdoption[]

  @@unique([orgId, name])
  @@index([orgId, archived])
  @@index([orgId, category])
}

// Records that a repo adopted a skill — the explicit reuse signal (mirror PlaybookApplication). One row
// per (skill, repo). `orgId` is denormalized for org-level rollups. No DB FKs (relationMode="prisma").
model OrgSkillAdoption {
  id           String   @id @default(uuid())
  skillId      String
  orgId        String // denormalized for org-scoped aggregation
  repoFullName String
  adoptedBy    String? // GitHub login who marked it adopted
  adoptedAt    DateTime @default(now())

  skill OrgSkill @relation(fields: [skillId], references: [id])

  @@unique([skillId, repoFullName])
  @@index([skillId])
  @@index([orgId])
}

// One rolling download/use tally row per skill (mirror BadgeImpression/QuotaEvent) — org-internal usage
// counter, bumped fire-and-forget on download or "copy for LLM". `OrgSkill.downloadCount` is the
// denormalized mirror used for sorting; this row additionally carries `lastSeen` (and is the seam for a
// future per-day trend). Standalone — keyed by skillId. Block-level @@unique keeps the inline-@unique
// parity list in init-sql.test.ts intact (same generated index name as an inline @unique).
model OrgSkillDownload {
  id       String   @id @default(uuid())
  skillId  String
  count    Int      @default(0)
  lastSeen DateTime @updatedAt

  @@unique([skillId])
}

// Auto-derived tech-stack group (Feature 3b) — a parallel, immutable grouping of an org's repos by
// detected stack (frontend / backend:<lang> / mobile / data_ml / infra / library), maintained by
// syncTechStackGroups on each scan. Distinct from the user-owned Segment (deliberately separate so
// auto-groups don't clutter the Segments UI). Multi-membership: a fullstack repo is in several groups.
// `key` is the stable identity (see techGroupsFor in src/lib/org/tech-stack.ts); `label` is display.
model TechStackGroup {
  id        String   @id @default(uuid())
  orgId     String
  key       String // "frontend" | "backend:node" | "backend:python" | "mobile" | "data_ml" | "infra" | "library"
  label     String // "Frontend", "Backend · Python"
  updatedAt DateTime @updatedAt

  org     Organization           @relation(fields: [orgId], references: [id])
  members TechStackGroupMember[]

  @@unique([orgId, key])
  @@index([orgId])
}

// Membership of a repo in a tech-stack group — the auto-maintained join (reconciled per scan). One row
// per (group, repo). Standalone cascade at the Prisma layer (no DB FKs under relationMode="prisma").
model TechStackGroupMember {
  id      String @id @default(uuid())
  groupId String
  repoId  String

  group TechStackGroup @relation(fields: [groupId], references: [id])
  repo  Repository     @relation(fields: [repoId], references: [id])

  @@unique([groupId, repoId])
  @@index([groupId])
  @@index([repoId])
}

// Per-org connected LLM (BYOM — Feature 1). One row per org: the org's own Amazon Bedrock provider so
// inference runs in THEIR AWS account/region/bill (the enterprise privacy unlock). The credential is
// stored ONLY in `credentialsEncrypted` (AES-256-GCM via src/lib/crypto/secret-box.ts) — never a plain
// column, never returned by the API, decrypted only at provider-construction time. `enabled=false`
// lets an org save+test before going live (or support pause a misconfig). Enterprise-plan gated +
// fail-closed without ENCRYPTION_KEY. See src/lib/db/org-llm.ts.
model OrgLlmConfig {
  id                   String    @id @default(uuid())
  orgId                String
  provider             String    @default("bedrock") // "bedrock" (v1); future: openai | vertex | self_hosted
  enabled              Boolean   @default(false) // configured-but-paused vs active
  modelId              String // e.g. "us.anthropic.claude-sonnet-4-6"
  region               String? // bedrock region
  authMode             String    @default("static") // "static" | (future) "assume_role"
  // Encrypted JSON blob (secret-box v1): { accessKeyId, secretAccessKey }. Null = no creds stored yet.
  credentialsEncrypted String?
  lastValidatedAt      DateTime? // set by the test-connection endpoint
  lastValidationError  String?
  createdBy            String? // GitHub login
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId])
}

// Server-side session revocation. The signed session cookie embeds the `sv` (session
// version) it was minted at; getSessionState re-checks it against this row on every
// resolve and rejects the cookie once the stored version is higher. Bumping the version —
// on logout, or when an installation the login owns is removed — invalidates every
// outstanding token for that login immediately, instead of waiting out the cookie TTL
// (the gap that made "logout" only delete the local cookie). Keyed by the GitHub login
// (lowercased), the same identity carried in the session. No row == version 0, so a
// never-revoked user costs nothing to store. Standalone (no FKs under relationMode =
// "prisma"); always read/written by its primary key. See src/lib/db/sessions.ts.
model SessionRevocation {
  login     String   @id // GitHub login, lowercased — matches Session.login
  version   Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Soft weekly quota for anonymous public scans, keyed by a SALTED HASH of the client IP (never the
// raw IP — avoids persisting PII). Persistent + cross-instance, which is the whole point: a 7-day
// window can't live in the per-minute in-memory burst limiter (src/lib/rate-limit.ts), since
// serverless instances reset and each keeps its own Map. This is a deliberately SOFT gate —
// knowingly attackable (IP rotation, shared NAT/CGNAT collisions) — that caps casual repeat use of
// the free, no-signup public scan and nudges heavy users to sign in. Enforced only when persistence
// is configured; the scan path fails OPEN if this store hiccups. `hits` is a JSON number[] of
// epoch-ms scan timestamps inside the rolling window, trimmed on each write. See
// src/lib/public-scan-quota.ts. Standalone under relationMode = "prisma" (no FKs); read/written by
// its primary key. Stale rows are swept by the retention purge job (src/lib/db/retention.ts).
model PublicScanQuota {
  ipHash    String   @id // SHA-256(salt + ":" + clientIp), hex — never the raw IP
  hits      String   @default("[]") // JSON number[] of epoch-ms timestamps in the rolling 7-day window
  updatedAt DateTime @updatedAt
}

// Best-effort reach tally for the public README badge (USE-1): one row per (repo, embedding host),
// counted up on each ORIGIN badge GET. Powers the "Badge reach" panel on /usage. Deliberately
// approximate — README badges are heavily proxy/CDN-cached (GitHub serves them through camo), so the
// majority of real views never reach the origin and aren't counted; this measures lower-bound reach +
// where embeds live. `repoFullName` is the lowercased "owner/repo"; `refererHost` the lowercased
// embedding host (or "direct" when no/unparseable Referer). No FK — keyed by the unique pair.
// Written fire-and-forget from src/app/api/badge/[owner]/[repo]/route.ts; read by src/lib/db/badge-analytics.ts.
model BadgeImpression {
  id           String   @id @default(uuid())
  repoFullName String // lowercased "owner/repo"
  refererHost  String // lowercased embedding host, or "direct"
  count        Int      @default(0)
  firstSeen    DateTime @default(now())
  lastSeen     DateTime @default(now())

  @@unique([repoFullName, refererHost])
  @@index([repoFullName])
}

// Public-funnel abuse observability (QUOTA-6): a running tally bumped fire-and-forget when the free
// funnel pushes back — a weekly-quota denial or a rate-limit trip — so /usage can show how often the
// guardrails fire. `kind` = "quota_deny" | "rate_limit"; `scope` = "anon"/"user" (quota) or the
// limiter name ("badge", …). No FK; keyed by the unique pair. Written best-effort from
// src/lib/public-scan-quota.ts + the badge route; read by src/lib/db/quota-events.ts.
model QuotaEvent {
  id        String   @id @default(uuid())
  kind      String
  scope     String
  count     Int      @default(0)
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([kind, scope])
}

// A record of each onboarding-skill generation (STD-6) — turns the one-off SKILL.md download into a
// tracked program: which tracks a repo's skill targeted, at which commit, when. `trackIds` is a JSON
// string[] of practice ids. Keyed by repoFullName; written best-effort from the skill route, read by
// src/lib/db/skill-history.ts to show a "skill history" + track-set diff on the report.
model SkillGeneration {
  id           String   @id @default(uuid())
  repoFullName String
  headSha      String?
  trackIds     String   @default("[]")
  generatedAt  DateTime @default(now())

  @@index([repoFullName])
}

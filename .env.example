# ─────────────────────────────────────────────────────────────────────────────
# Ascent — environment variables
# Copy to .env.local and fill in. Everything is optional: with no keys at all,
# Ascent runs in deterministic "mock" mode — fully functional, just without
# LLM-written nuance.
# ─────────────────────────────────────────────────────────────────────────────

# Which LLM backend to use:
#   gemini     -> Google Gemini       (LOCAL DEV & TESTING — recommended here)
#   bedrock    -> AWS Bedrock/Claude   (PHASE 2 / production, enterprise privacy)
#   claude-cli -> local `claude` CLI   (LOCAL EVAL — uses your Pro/Max subscription)
#   openai     -> OpenAI or any OpenAI-compatible Chat Completions API
#   mock       -> deterministic, keyless
#   auto       -> (default) gemini if a key is present, else mock
# Keep this as `gemini` locally; set to `bedrock` in production env.
LLM_PROVIDER=gemini

# Optional cross-provider tuning:
# LLM_FALLBACK_PROVIDER=mock     # retry with this provider if the primary errors (e.g. mock, gemini)
# LLM_TIMEOUT_MS=120000          # per-call timeout for the gemini/openai HTTP clients (ms)

# ── claude-cli provider (local eval via subscription) — see docs/CALIBRATION.md ──
# Requires the `claude` CLI installed + logged in (claude /login). Spawns it headlessly;
# uses your subscription, NOT pay-per-token, as long as ANTHROPIC_API_KEY is unset.
# CLAUDE_MODEL=sonnet           # or opus, or a pinned id like claude-sonnet-4-6
# CLAUDE_CLI_PATH=claude        # override if not on PATH
# CLAUDE_CLI_TIMEOUT_MS=120000

# ── Gemini (local dev) ───────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GOOGLE_API_KEY is accepted as an alias for GEMINI_API_KEY (whichever is set is used).
# Optional: override the model (default gemini-3-flash-preview; GA: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3-flash-preview

# ── OpenAI (or any OpenAI-compatible endpoint) — set LLM_PROVIDER=openai ──────
# Works with OpenAI proper or a compatible gateway (Azure OpenAI, OpenRouter, or a local
# server like Ollama / LM Studio that speaks the Chat Completions API).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini          # model id (any chat-completions model your endpoint serves)
# OPENAI_BASE_URL=                  # override the API base for a compatible endpoint

# ── AWS Bedrock (Phase 2 / enterprise) ───────────────────────────────────────
# Uses your standard AWS credentials (AWS_PROFILE / AWS_ACCESS_KEY_ID + SECRET,
# or an IAM role on Vercel/AWS). Default model is the latest Claude Sonnet (4.6)
# via the US geo inference profile (data stays in-US, works in us-east-1).
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
#   alternatives: global.anthropic.claude-sonnet-4-6  (max throughput)
#                 eu.anthropic.claude-sonnet-4-6      (EU residency)

# ── GitHub (optional) ────────────────────────────────────────────────────────
# Raises API rate limits for public scans. Fine-grained token, read-only
# "Contents" + "Metadata".
# GITHUB_TOKEN=

# ── GitHub App (private repositories) — see docs/GITHUB_APP.md ───────────────
# Lets users install Ascent on their org to scan private repos via short-lived
# installation tokens. Requires DATABASE_URL. Public scans don't need this.
#
# Permissions the App needs, by feature:
#   • Scanning private repos        → Contents: read, Metadata: read, Pull requests: read
#   • PR maturity gate (checks/comment) → Checks: write, Pull requests: write
#   • Practice "open starter PR"    → Contents: write, Pull requests: write
# Webhook events to subscribe to: Installation, Pull request, Push.
# GITHUB_APP_ID=
# GITHUB_APP_SLUG=ascent-maturity
# GITHUB_APP_WEBHOOK_SECRET=
# Base64-encoded PEM (recommended) or raw PEM with \n escapes:
# GITHUB_APP_PRIVATE_KEY=

# ── GitHub OAuth (sign-in) — see docs/GITHUB_APP.md §4 ──────────────────────
# Reuse the SAME GitHub App's Client ID + a generated client secret, so a signed-in
# user's token can list THEIR installations. Set the App's Callback URL to
# {host}/api/auth/callback. AUTH_SECRET signs the session cookie (any long random string,
# e.g. `openssl rand -base64 32`). When unset, the app runs without sign-in (pages open).
# NOTE: this is the LEGACY custom OAuth flow. It is kept but dormant — the active login is
# Supabase (below). Leave these unset unless you specifically want the custom flow.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# AUTH_SECRET=

# ── Supabase GitHub OAuth (ACTIVE sign-in) — the login wall ──────────────────
# The active authentication layer. When both vars below are set (and ASCENT_AUTH_BYPASS is
# off), private/org scans and all /org/* features require signing in with GitHub via Supabase;
# public-repo scans stay free / no-signup. When unset, the app runs open exactly as before.
#
# Supabase dashboard prerequisite (one-time): Authentication → Providers → enable GitHub and
# paste a GitHub OAuth App's Client ID/secret (its callback = {SUPABASE_URL}/auth/v1/callback);
# then Authentication → URL Configuration → add {host}/auth/callback to the Redirect URLs
# (e.g. http://localhost:3000/auth/callback).
#
# The anon key is public by design (Row-Level Security protects data) — safe to expose client-side.
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev/local only: bypass the Supabase login wall entirely — every gate passes as a synthetic
# "developer" viewer, so all functionality is reachable without signing in. Default OFF. Set to 1
# during development; set to 0 (or remove) to exercise the real sign-in flow.
# ASCENT_AUTH_BYPASS=1

# ── Autoscans + live intelligence (enterprise) ──────────────────────────────
# Vercel Cron hits /api/cron/rescan (see vercel.json). Set a secret to protect it;
# Vercel sends it as `Authorization: Bearer <CRON_SECRET>`.
# CRON_SECRET=
#
# Regression alerts (Feature: live intelligence). After an autoscan or a push-triggered
# re-scan, Ascent diffs the new report against the prior one; on a regression (level demotion,
# slide into "ungoverned", or a material score drop) it POSTs a Slack-compatible message here.
# Unset = alerts are computed + audit-logged but not dispatched. A Slack incoming-webhook URL works.
# ALERT_WEBHOOK_URL=
#
# Public base URL of this deployment — used to build absolute links in alerts + PR check
# "details" URLs (e.g. https://ascent.yourco.dev). Falls back to relative links when unset.
# ASCENT_PUBLIC_URL=
# NEXT_PUBLIC_APP_URL is accepted as a fallback alias for ASCENT_PUBLIC_URL (also used by
# robots.ts / sitemap.ts to emit absolute URLs).

# ── Database (Phase 2 — not used by the MVP) ─────────────────────────────────
# Local dev: point at the docker-compose Postgres (see docker-compose.yml).
# Production: point at your Aurora DSQL cluster (Postgres-compatible).
# Aurora DSQL has no local emulator, but a perpetual free tier (100k DPU + 1GB/mo).
# DATABASE_URL=postgres://ascent:ascent@localhost:5432/ascent
#
# Aurora DSQL IAM auth (production). Setting DSQL_ENDPOINT switches the Prisma client into
# token-refresh mode: the connection password is a short-lived IAM token, minted via
# @aws-sdk/dsql-signer (run `npm i @aws-sdk/dsql-signer`) and auto-refreshed before its TTL
# elapses — so the cached client never goes stale after deploy. See src/lib/db/client.ts and
# docs/ARCHITECTURE.md §3-4. Region falls back to AWS_REGION / AWS_DEFAULT_REGION.
# DSQL_ENDPOINT=                        # cluster host, e.g. abc123.dsql.us-east-1.on.aws
# DSQL_REGION=us-east-1
# DSQL_USER=admin                       # admin -> admin auth token; otherwise db-connect token
# DSQL_DATABASE=postgres
# DSQL_PORT=5432
# DSQL_SSLMODE=require
# DSQL_TOKEN_TTL_SECONDS=900            # token lifetime requested from the signer (~15 min)
# DSQL_REFRESH_MARGIN_SECONDS=120       # refresh this long before the token expires

# ── Supply-chain scanning (org Security tab — Dependabot advisories) ─────────
# Surfaces open Dependabot advisory counts per repo on the Security tab as a SEPARATE signal — it does
# NOT change the D9 score. Live mode requires the GitHub App to be granted "Dependabot alerts: read".
#   github -> live alerts via the org's installation token
#   mock   -> deterministic demo data (labelled "demo" in the UI)
#   off    -> (default) no supply-chain card
# SUPPLY_CHAIN_PROVIDER=off

# ── Cost metering (the /usage dollar estimate) ───────────────────────────────
# Per-million-token prices used to turn recorded token usage into a $ estimate. Set these to your
# actual negotiated rates; unset = a built-in default. Input/output priced separately.
# LLM_INPUT_COST_PER_MTOK=0.30
# LLM_OUTPUT_COST_PER_MTOK=2.50

# ── Retention / pruning (DB housekeeping; driven by /api/cron/purge) ──────────
# RETENTION_MAX_SCANS_PER_REPO=        # keep at most N scans per repo (older ones pruned). Unset = keep all.
# RETENTION_AUDIT_DAYS=                # delete audit-log rows older than N days. Unset = keep all.
# RETENTION_BATCH_SIZE=500             # rows deleted per pruning batch.

# ── Public-scan weekly soft gate (anonymous free funnel; per-IP, persistent) ──
# Caps anonymous PUBLIC scans at N per rolling 7-day window per client IP (a salted-hash key — the
# raw IP is never stored). A deliberately SOFT, knowingly-attackable nudge layered ON TOP of the
# per-minute in-memory burst limiter; requires a configured DB and fails OPEN if the store errors.
# See src/lib/public-scan-quota.ts.
# PUBLIC_SCAN_WEEKLY_LIMIT=3            # free public scans per ANONYMOUS IP per 7 days. Default 3.
# PUBLIC_SCAN_WEEKLY_LIMIT_SIGNED_IN=20 # elevated allowance for a SIGNED-IN viewer (per-user bucket).
#                                       # Default 20; clamped to never drop below the anonymous limit.
# PUBLIC_SCAN_QUOTA_SALT=               # salt for the stored hashes. Set a real secret in prod.
# PUBLIC_SCAN_QUOTA_DISABLED=           # set to 1 to turn the weekly gate off entirely.

# Local/demo only: open per-org dashboards (/org/<slug>) when OAuth is NOT configured. Default off.
# Required for the seeding + org-e2e workflow (auth-off) to READ a seeded org dashboard; leave
# unset in any real deployment so a dropped AUTH_SECRET can never make per-tenant data public.
# ASCENT_OPEN_ORG_DASHBOARDS=1

# Dev/demo only: allow owner-gated MANUAL scan-credit grants via POST /api/org/credits/grant. Default
# off — in production, prepaid scan credits are added by the billing/Stripe top-up flow (see
# docs/BILLING.md), never a self-serve endpoint. Enable this to seed credits locally for testing.
# ASCENT_ALLOW_CREDIT_GRANTS=1
